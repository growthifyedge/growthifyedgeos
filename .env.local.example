# =============================================================================
# Growthify Edge OS — Environment Variables
# Copy this file to `.env.local` and fill in the values from your Supabase project
# (Supabase Dashboard → Project Settings → API).
# =============================================================================

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser. Used by admin server actions
# (e.g. creating agent accounts). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for auth redirects). Set to your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# WhatsApp Cloud API (auto-responder) — from the Meta / Facebook Developer app.
# See docs/WHATSAPP_SETUP.md for exactly where each of these comes from.
# =============================================================================

# A secret string YOU invent (any random text). You paste the SAME value into
# the Meta dashboard when configuring the webhook "Verify token".
WHATSAPP_VERIFY_TOKEN=make-up-a-long-random-string-here

# "Phone number ID" — Meta dashboard → WhatsApp → API Setup (NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Access token. Use a PERMANENT System User token for production
# (the temporary one in API Setup expires after 24 hours).
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token

# --- Dashboard login (protects the WhatsApp inbox at "/") ---
# If DASHBOARD_PASSWORD is set, the inbox asks for a username + password
# (browser popup). If left blank, the inbox is open to anyone with the link.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=choose-a-strong-password
