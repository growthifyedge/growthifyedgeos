# =============================================================================
# Growthify Edge OS — Environment Variables
# Copy this file to `.env.local` and fill in the values from your Supabase project
# (Supabase Dashboard → Project Settings → API).
# =============================================================================

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser. Used by admin server actions
# (e.g. creating agent accounts). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for auth redirects). Set to your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
